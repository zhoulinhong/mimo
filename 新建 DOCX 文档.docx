def solve_n_queens(n):
    def is_safe(row, col):
        for i in range(row):
            if cols[i] == col or abs(cols[i] - col) == abs(i - row):
                return False
        return True

    def backtrack(row):
        if row == n:
            solutions.append(cols[:])
            return
        for col in range(n):
            if is_safe(row, col):
                cols[row] = col
                backtrack(row + 1)
                cols[row] = -1

    solutions = []
    cols = [-1] * n
    backtrack(0)
    return solutions

# 输出解的可视化形式
def print_solutions(solutions, n):
    for sol in solutions:
        print("Solution:")
        for i in range(n):
            row = ['.'] * n
            row[sol[i]] = 'Q'
            print(' '.join(row))
        print()

n = 4
solutions = solve_n_queens(n)
print(f"Total solutions for {n}-queens: {len(solutions)}")
print_solutions(solutions, n)